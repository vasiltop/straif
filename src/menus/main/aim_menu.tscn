[gd_scene load_steps=4 format=4]

[ext_resource type="Script" path="res://src/menus/main/aim_menu.gd" id="1_script"]
[ext_resource type="Theme" path="res://src/main_theme.tres" id="2_theme"]
[ext_resource type="StyleBox" path="res://src/panel_style.tres" id="3_panel"]

[node name="AimMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2_theme")
script = ExtResource("1_script")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 24

[node name="Content" type="VBoxContainer" parent="Margin"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 18

[node name="Title" type="Label" parent="Margin/Content"]
layout_mode = 2
theme_override_font_sizes/font_size = 34
text = "Aim Trainer"

[node name="Subtitle" type="Label" parent="Margin/Content"]
layout_mode = 2
theme_override_colors/font_color = Color(0.776471, 0.815686, 0.866667, 1)
theme_override_font_sizes/font_size = 18
text = "Choose a focused 60-second scenario, warm up your mechanics, and compare every run on the live leaderboard."
autowrap_mode = 3

[node name="ScenarioList" type="HFlowContainer" parent="Margin/Content"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/h_separation = 12
theme_override_constants/v_separation = 12

[node name="GridshotOption" type="PanelContainer" parent="Margin/Content/ScenarioList"]
custom_minimum_size = Vector2(220, 0)
layout_mode = 2
size_flags_horizontal = 3
theme_override_styles/panel = ExtResource("3_panel")

[node name="OptionContent" type="MarginContainer" parent="Margin/Content/ScenarioList/GridshotOption"]
layout_mode = 2
theme_override_constants/margin_left = 16
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 16
theme_override_constants/margin_bottom = 16

[node name="OptionStack" type="VBoxContainer" parent="Margin/Content/ScenarioList/GridshotOption/OptionContent"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="GridshotButton" type="Button" parent="Margin/Content/ScenarioList/GridshotOption/OptionContent/OptionStack"]
layout_mode = 2
toggle_mode = true
text = "GRIDSHOT"

[node name="Description" type="Label" parent="Margin/Content/ScenarioList/GridshotOption/OptionContent/OptionStack"]
layout_mode = 2
theme_override_colors/font_color = Color(0.662745, 0.701961, 0.756863, 1)
theme_override_font_sizes/font_size = 16
text = "Clear a 3x3 wall of targets for chaining speed and accuracy."
autowrap_mode = 3

[node name="FlickOption" type="PanelContainer" parent="Margin/Content/ScenarioList"]
