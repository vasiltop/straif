{
  "name": "server",
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "test": "tsx --test src/*.test.ts",
    "build": "tsc && tsup src/index.ts src/migrate.ts --format esm --outDir dist",
    "start": "node dist/index.js",
    "populate": "node scripts/populate.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "lint:server": "oxlint --deny-warnings --type-aware --type-check src drizzle.config.ts",
    "lint:scripts": "oxlint --deny-warnings scripts",
    "lint:website": "cd .. && oxlint --deny-warnings --vue-plugin website/src website/vite.config.js",
    "lint": "pnpm lint:server && pnpm lint:scripts && pnpm lint:website",
    "format": "cd .. && oxfmt server/src server/drizzle.config.ts server/scripts website/src website/vite.config.js",
    "format:check": "cd .. && oxfmt --check server/src server/drizzle.config.ts server/scripts website/src website/vite.config.js",
    "quality": "pnpm format:check && pnpm lint"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@hono/standard-validator": "^0.2.0",
    "@hono/swagger-ui": "^0.5.2",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "discord.js": "^14.21.0",
    "dotenv": "^16.6.0",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.11.2",
    "hono-openapi": "^1.3.1",
    "pg": "^8.16.2",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.15.4",
    "drizzle-kit": "^0.31.3",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
